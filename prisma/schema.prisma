generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- NEXTAUTH KÖTELEZŐ TÁBLÁI (Google Login-hoz) ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user") // voter, exhibitor, admin
  accounts      Account[]
  sessions      Session[]
  
  // Saját relációk
  cars          Car[]     // Ha kiállító, lehetnek autói
  votes         Vote[]    // A leadott szavazatai
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- SAJÁT TÁBLÁK (Autós Szavazás) ---

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  isActive  Boolean  @default(true)
  votes     Vote[]
}

model Car {
  id          Int      @id @default(autoincrement())
  startNumber Int      @unique
  name        String
  description String?  @db.Text
  imageUrl    String?
  galleryImages String[]
  createdAt   DateTime @default(now())
  
  exhibitorId String?
  exhibitor   User?    @relation(fields: [exhibitorId], references: [id], onDelete: SetNull)
  
  votes       Vote[]
}

model Vote {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())
  
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  carId      Int
  car        Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // SPAM VÉDELEM: Egy user egy kategóriában csak egyszer szavazhat!
  @@unique([userId, categoryId])
}

model Setting {
  id           String  @id @default("global")
  isVotingOpen Boolean @default(true) // Alapból nyitva van a szavazás
}